@model IEnumerable<Client>

@{
    ViewData["Title"] = "Clients";
}

<link rel="stylesheet" href="~/css/client.css" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">Clients</h2>
        <a href="/Client/Create" class="btn btn-primary">+ New Client</a>
    </div>

    <div class="card">
        <div class="card-header">
            <input type="text" id="searchInput" class="search-box form-control" placeholder="🔍 Search by name or email...">
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0 client-table" id="clientTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Registration Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model)
                    {
                        <tr>
                            <td>@client.Name</td>
                            <td>@client.Email</td>
                            <td>@client.Phone</td>
                            <td>@client.RegistrationDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="/Client/Edit/@client.Id" class="btn btn-sm btn-warning">Edit</a>
                                <form action="/Client/Delete/@client.Id" method="post" style="display:inline">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Delete this client?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

    @section Scripts {
        <script>
            $("#searchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#clientTable tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        </script>
    }