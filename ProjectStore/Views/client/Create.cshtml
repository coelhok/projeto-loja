@model Client

@{
    ViewData["Title"] = "New Client";
}

<link rel="stylesheet" href="~/css/client.css" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">New Client</h2>
        <a href="/Client" class="btn btn-secondary">← Back</a>
    </div>

    <div class="card">
        <div class="card-header">
            <span>Fill in the client details</span>
        </div>
        <div class="card-body">
            <form action="/Client/Create" method="post" class="client-form">
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" name="Name" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="Email" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" name="Phone" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/Client" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>